generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  displayName      String
  role             UserRole @default(USER)
  timezone         String   @default("UTC")
  bio              String?  @db.VarChar(280)
  showInSearch     Boolean  @default(true)
  xpTotal          Int      @default(0)
  level            Int      @default(1)
  gems             Int      @default(0)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lessonProgress   UserLessonProgress[]
  exerciseProgress UserExerciseProgress[]
  exerciseAttempts UserExerciseAttempt[]
  courseEnrollments UserCourseEnrollment[]
  trackEnrollments  UserTrackEnrollment[]
  followingLinks    UserFollow[] @relation("FollowerSide")
  followerLinks     UserFollow[] @relation("FollowingSide")
}

/// A segue B: followerId = A, followingId = B
model UserFollow {
  followerId  String
  follower    User     @relation("FollowerSide", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("FollowingSide", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Track {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  tagline     String?  @db.VarChar(160)
  /// Imagem de capa (URL) para a página de apresentação da trilha antes da matrícula.
  coverImageUrl String? @db.VarChar(2048)
  /// Conteúdo longo em Markdown: visão geral, público-alvo, exemplos (usado na landing).
  overviewMd  String?  @db.LongText
  orderIndex  Int      @default(0)
  courses     Course[]
  enrollments UserTrackEnrollment[]
}

model Course {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  isFree      Boolean  @default(true)
  /// Se true, novos logins e cadastros são matriculados automaticamente neste curso (quando isFree).
  autoEnrollOnAuth Boolean @default(true)
  modules     Module[]
  enrollments UserCourseEnrollment[]

  @@unique([trackId, slug])
  @@index([trackId])
}

model UserCourseEnrollment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
}

model UserTrackEnrollment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId    String
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([userId, trackId])
  @@index([userId])
}

model Module {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  orderIndex Int      @default(0)
  lessons    Lesson[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model Lesson {
  id               String   @id @default(cuid())
  moduleId         String
  module           Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug             String
  title            String
  objective        String?  @db.Text
  contentMd        String   @db.Text
  estimatedMinutes Int      @default(3)
  orderIndex       Int      @default(0)
  exercises        Exercise[]
  userProgress     UserLessonProgress[]

  @@unique([moduleId, slug])
  @@index([moduleId])
}

model Exercise {
  id          String       @id @default(cuid())
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type        ExerciseType
  title       String
  prompt      String       @db.Text
  explanation String       @db.Text
  payload     Json
  xpReward    Int          @default(10)
  gemReward   Int          @default(1)
  orderIndex  Int          @default(0)
  attempts    UserExerciseAttempt[]
  progress    UserExerciseProgress[]

  @@index([lessonId])
}

enum ExerciseType {
  MULTIPLE_CHOICE
  CODE_FILL
  CODE_EDITOR
}

model UserLessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model UserExerciseProgress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  solved     Boolean  @default(false)
  solvedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, exerciseId])
  @@index([userId])
}

model UserExerciseAttempt {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  correct    Boolean
  answer     Json?
  createdAt  DateTime @default(now())

  @@index([userId, exerciseId])
}
